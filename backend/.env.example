# ===== 阿里云百炼（DashScope）统一接入 =====
# DeepSeek（纯文本翻译/解释）和 Qwen-VL（多模态/OCR/看图）共用此 Key 与 endpoint。
# 控制台: https://bailian.console.aliyun.com/  →  API-KEY 管理
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 纯文本模型（百炼上的 DeepSeek）
DEEPSEEK_MODEL=deepseek-v4-pro
# DeepSeek 思考模式: true=流式输出思考过程(reasoning)+回复(content), false=仅回复
ENABLE_THINKING=true

# 多模态模型（百炼上的 Qwen-VL）
QWEN_VL_MODEL=qwen-vl-max

# ===== 通用 =====
DEFAULT_TARGET_LANG=zh
HTTP_TIMEOUT_CONNECT=10
HTTP_TIMEOUT_STREAM=120
# 允许的前端来源, 逗号分隔
# 允许的前端来源, 逗号分隔 (5173=Vite dev, 8000=内嵌后端生产源)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8000
